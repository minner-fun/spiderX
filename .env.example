# ===== SpiderX 环境变量（复制为 .env，绝不提交真实密钥）=====
# Postgres
POSTGRES_USER=spiderx
POSTGRES_PASSWORD=spiderx_dev_pwd
POSTGRES_DB=spiderx

# 后端/worker 连接（容器内用服务名 postgres / redis）
DATABASE_URL=postgresql+asyncpg://spiderx:spiderx_dev_pwd@postgres:5432/spiderx
DATABASE_URL_SYNC=postgresql+psycopg://spiderx:spiderx_dev_pwd@postgres:5432/spiderx
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# 安全
SECRET_KEY=change_me_in_real_env

# 运行环境
ENV=dev
